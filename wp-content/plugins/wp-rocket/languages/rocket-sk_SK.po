msgid ""
"Specify URLs you always want purged from cache whenever you update any post "
"or page (one per line)"
msgstr ""
"Uveďte URL adresy, ktoré chcete vždy vymazať z cache pri každej aktualizácii"
" príspevku alebo stránky (jedna na riadok)."

#: inc/Engine/Admin/Settings/Page.php:1343
msgid "Specify query strings for caching (one per line)"
msgstr "Špecifikujte reťazce dopytov pre ukladanie do cache (jeden na riadok)"

