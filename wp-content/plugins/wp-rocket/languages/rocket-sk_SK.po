"%1$sPlanning on using Automatic Platform Optimization (APO)?%2$s Just "
"activate the official Cloudflare plugin and configure it. WP Rocket will "
"automatically enable compatibility."
msgstr ""
"%1$sPlánujete používať funkciu Automatickej optimalizácie platformy "
"(APO)?%2$s Stačí si aktivovať oficiálny plugin Cloudflare a nakonfigurovať "
"ju. WP Rocket automaticky povolí kompatibilitu."

#: inc/Engine/Admin/Settings/Page.php:1923
msgid "Varnish"
msgstr "Varnish"

#: inc/Engine/Admin/Settings/Page.php:1929
msgid "If Varnish runs on your server, you must activate this add-on."
msgstr ""
"Ak na vašom serveri beží Varnish, je potrebné aktivovať toto rozšírenie."

#. translators: %1$s = opening <a> tag, %2$s = closing </a> tag.
#: inc/Engine/Admin/Settings/Page.php:1931
#, php-format
