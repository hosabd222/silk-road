msgid ""
"Specify URLs of pages or posts that should never be cached (one per line)"
msgstr ""
"Špecifikujte URL adresy stránok alebo príspevkov, ktoré by sa nikdy nemali "
"cacheovať (jedna na riadok)"

#: inc/Engine/Admin/Settings/Page.php:1307
#: inc/Engine/Admin/Settings/Page.php:1335
msgid ""
"The domain part of the URL will be stripped automatically.<br>Use (.*) "
"wildcards to address multiple URLs under a given path."
msgstr ""
"Časť domény v URL adrese bude automaticky odstránená. <br>Použite zástupné "
"znaky (.*) na adresovanie viacerých URL adries v danej ceste."

#: inc/Engine/Admin/Settings/Page.php:1316
msgid ""
"Specify full or partial IDs of cookies that, when set in the visitor's "
"browser, should prevent a page from getting cached (one per line)"
msgstr ""
"Špecifikujte úplné alebo čiastočné ID súborov cookies, ktoré by po nastavení"
" v prehliadači návštevníka mali zabrániť cacheovaniu stránky (jedno ID na "
"riadok)."

#: inc/Engine/Admin/Settings/Page.php:1324
msgid ""
"Specify user agent strings that should never see cached pages (one per line)"
msgstr ""
"Špecifikujte reťazce používateľského agenta, ktoré by nikdy nemali vidieť "
"stránky uložené v pamäti cache (jeden na riadok)"

#: inc/Engine/Admin/Settings/Page.php:1325
msgid "Use (.*) wildcards to detect parts of UA strings."
msgstr "Na detekciu častí reťazcov UA použite zástupné znaky (.*) ."

