u0631\u062c \u062e\u0648\u0627\u0647\u062f \u0634\u062f."],"Access revoked":["\u062f\u0633\u062a\u0631\u0633\u06cc \u0627\u0628\u0637\u0627\u0644 \u0634\u062f"],"It wasn't you? Revoke access":["\u0634\u0645\u0627 \u0646\u0628\u0648\u062f\u06cc\u062f\u061f \u0644\u063a\u0648 \u062f\u0633\u062a\u0631\u0633\u06cc"],"We could not generate the login code. Please renew and try again.":["\u0627\u0645\u06a9\u0627\u0646 \u062a\u0648\u0644\u06cc\u062f \u06a9\u062f \u0648\u0631\u0648\u062f \u0648\u062c\u0648\u062f \u0646\u062f\u0627\u0631\u062f. \u0644\u0637\u0641\u0627 \u06a9\u062f \u0631\u0627 \u062a\u0627\u0632\u0647\u200c\u0633\u0627\u0632\u06cc \u06a9\u0631\u062f\u0647 \u0648 \u062f\u0648\u0628\u0627\u0631\u0647 \u062a\u0644\u0627\u0634 \u06a9\u0646\u06cc\u062f."],"Renew code":["\u062a\u0627\u0632\u0647\u200c\u0633\u0627\u0632\u06cc \u06a9\u062f"],"Code expires in %s":["\u06a9\u062f \u062a\u0627 %s \u0645\u0646\u0642\u0636\u06cc \u0645\u06cc\u200c\u0634\u0648\u062f"],"Start over":["\u0634\u0631\u0648\u0639 \u062f\u0648\u0628\u0627\u0631\u0647"],"Sign-in denied. For your security, this attempt has been cancelled.":["\u0648\u0631\u0648\u062f \u0631\u062f \u0634\u062f. \u0628\u0631\u0627\u06cc \u0627\u0645\u0646\u06cc\u062a \u0634\u0645\u0627\u060c \u0627\u06cc\u0646 \u062a\u0644\u0627\u0634 \u0644\u063a\u0648 \u0634\u062f."],"Confirmed. Finishing sign-in on your phone\u2026":["\u062a\u0627\u06cc\u06cc\u062f \u0634\u062f. \u062f\u0631 \u062d\u0627\u0644 \u0627\u062a\u0645\u0627\u0645 \u0648\u0631\u0648\u062f \u0628\u0647 \u062a\u0644\u0641\u0646 \u0634\u0645\u0627\u2026"],"We could not load the confirmation challenge. Please try again.":["\u0645\u0627 \u0646\u062a\u0648\u0627\u0646\u0633\u062a\u06cc\u0645 \u0686\u0627\u0644\u0634 \u062a\u0627\u06cc\u06cc\u062f \u0631\u0627 \u0628\u0627\u0631\u06af\u0630\u0627\u0631\u06cc \u06a9\u0646\u06cc\u0645. \u0644\u0637\u0641\u0627 \u062f\u0648\u0628\u0627\u0631\u0647 \u0627\u0645\u062a\u062d\u0627\u0646 \u06a9\u0646\u06cc\u062f."],"Generate new code":["\u062a\u0648\u0644\u06cc\u062f \u06a9\u062f \u062c\u062f\u06cc\u062f"],"The login code has expired.":["\u06a9\u062f \u0648\u0631\u0648\u062f \u0645\u0646\u0642\u0636\u06cc \u0634\u062f\u0647 \u0627\u0633\u062a."],"Generating secure login code\u2026":["\u062f\u0631 \u062d\u0627\u0644 \u062a\u0648\u0644\u06cc\u062f \u06a9\u062f \u0648\u0631\u0648\u062f \u0627\u0645\u0646\u2026"],"Checking sign-in availability\u2026":["\u062f\u0631 \u062d\u0627\u0644 \u0628\u0631\u0631\u0633\u06cc \u062f\u0631 \u062f\u0633\u062a\u0631\u0633 \u0628\u0648\u062f\u0646 \u0648\u0631\u0648\u062f \u0628\u0647 \u0633\u06cc\u0633\u062a\u0645\u2026"],"On most hosts, application passwords also require an HTTPS connection.":["\u062f\u0631 \u0628\u06cc\u0634\u062a\u0631 \u0645\u06cc\u0632\u0628\u0627\u0646\u200c\u0647\u0627\u060c \u06af\u0630\u0631\u0648\u0627\u0698\u0647\u200c\u0647\u0627\u06cc \u0627\u067e\u0644\u06cc\u06a9\u06cc\u0634\u0646 \u0628\u0647 \u0627\u062a\u0635\u0627\u0644 HTTPS \u0646\u06cc\u0627\u0632 \u062f\u0627\u0631\u0646\u062f."],"A custom code snippet using the wp_is_application_passwords_available filter may have disabled them.":["\u06cc\u06a9 \u0642\u0637\u0639\u0647 \u06a9\u062f \u0633\u0641\u0627\u0631\u0634\u06cc \u0628\u0627 \u0627\u0633\u062a\u0641\u0627\u062f\u0647 \u0627\u0632 \u0641\u06cc\u0644\u062a\u0631 wp_is_application_passwords_available \u0645\u0645\u06a9\u0646 \u0627\u0633\u062a \u0622\u0646\u200c\u0647\u0627 \u0631\u0627 \u063a\u06cc\u0631\u0641\u0639\u0627\u0644 \u06a9\u0631\u062f\u0647 \u0628\u0627\u0634\u062f."],"A security plugin (e.g. Wordfence, Solid Security, iThemes Security) may have disabled application passwords.":["\u06cc\u06a9 \u0627\u0641\u0632\u0648\u0646\u0647 \u0627\u0645\u0646\u06cc\u062a\u06cc (\u0645\u062b\u0644 Wordfence\u060c Solid Security\u060c iThemes Security) \u0645\u0645\u06a9\u0646 \u0627\u0633\u062a \u0631\u0645\u0632\u0647\u0627\u06cc \u0639\u0628\u0648\u0631 \u0627\u067e\u0644\u06cc\u06a9\u06cc\u0634\u0646 \